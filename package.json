{
  "name": "kocpy",
  "version": "1.12.2",
  "description": "Professional DIT media backup software",
  "main": "out/main/index.js",
  "productName": "Kocpy",
  "author": "KocardPro",
  "license": "MIT",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --mac --arm64 --x64",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.kocpy.app",
    "productName": "Kocpy",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 180,
          "y": 180,
          "type": "file"
        },
        {
          "x": 480,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 330,
          "y": 340,
          "type": "file",
          "path": "resources/安装 Kocpy.command"
        }
      ]
    }
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.4",
    "@astryxdesign/theme-neutral": "^0.1.4",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.0",
    "exiftool-vendored": "^36.0.0",
    "ffmpeg-static": "^5.3.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.0",
    "lucide-react": "^0.475.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^14.2.0",
    "react-router-dom": "^6.22.0",
    "uuid": "^9.0.0",
    "xxhash-wasm": "^1.1.0",
    "zustand": "^4.5.0"
  }
}
